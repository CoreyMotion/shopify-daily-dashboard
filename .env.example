# Shopify Admin API credentials
# Copy this file to .env and fill in your values

# Your store's myshopify subdomain (e.g. "my-store" from my-store.myshopify.com)
SHOPIFY_STORE_NAME=your-store-name

# Admin API access token (from Shopify Admin > Apps > Develop apps > your app > API credentials)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API version to use (recommend keeping current)
SHOPIFY_API_VERSION=2024-01

# Sources excluded from order count AND revenue (comma-separated source_name values)
# These are system/draft orders that Shopify's dashboard hides
EXCLUDE_ORDER_SOURCES=shopify_draft_order,3426665

# Sources counted as orders but excluded from revenue (comma-separated)
# Shopify attributes their revenue to the originating channel, not the app
EXCLUDE_REVENUE_SOURCES=1520611,Edit Order
